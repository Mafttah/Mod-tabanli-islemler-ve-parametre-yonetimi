_count < MAX_BUFFER:\n            data_buffer[buffer_count] = sample\n            buffer_count += 1\n            serial.write_line(\"COLLECT | Buffer[\" + str(buffer_count) + \"/\" + str(MAX_BUFFER) + \"]: \" + sample)\n\n        if buffer_count >= MAX_BUFFER:\n            # Otomatik mod gecisi - buffer dolu, verileri kaybetmemek icin TRANSMIT'e gec\n            serial.write_line(\"COLLECT | Buffer dolu! TRANSMIT moduna geciliyor...\")\n            change_mode(\"TRANSMIT\")\n\n    # ---- TRANSMIT MODU ----\n    # Gonderim modu: canli sensor verisini okur ve hemen radyo ile gonderir.\n    # Ayrica buffer'da biriken tum verileri gonderir ve sonra buffer'i bosaltir.\n    def mode_transmit():\n        global buffer_count\n\n        # --- CANLI VERI GONDERIMI ---\n        # Anlık sensor degerlerini oku ve S:<id>:<temp>:<light> formatinda gonder\n        temp = input.temperature()\n        light_level = input.light_level()\n        live_msg = \"S:\" + str(satellite_id) + \":\" + str(temp) + \":\" + str(light_level)\n        radio.send_string(live_msg)\n        serial.write_line(\"TRANSMIT | Canli: \" + live_msg)\n\n        # --- BUFFER'DAKI VERILERI GONDER ---\n        # Buffer'da kayitli olan tum ornekleri sirayla gonder\n        i = 0\n        while i < buffer_count:\n            buffered_msg = \"S:\" + str(satellite_id) + \":\" + data_buffer[i]\n            radio.send_string(buffered_msg)\n            serial.write_line(\"TRANSMIT | Buffer[\" + str(i) + \"]: \" + buffered_msg)\n            i += 1\n\n        # Buffer'i bosalt - tum veriler gonderildi\n        if buffer_count > 0:\n            serial.write_line(\"TRANSMIT | Buffer bosaltildi (\" + str(buffer_count) + \" kayit gonderildi).\")\n        buffer_count = 0\n\n    # ============================================\n    # MOD DEGISTIRME\n    # ============================================\n\n    # Gecerli modu yeni bir modla degistirir ve durum bildirimi gonderir.\n    def change_mode(new_mode):\n        global current_mode\n\n        # Zaten bu modda olup olmadigini kontrol et (gereksiz gecisi engelle)\n        if current_mode == new_mode:\n            serial.write_line(\"MOD DEGISIMI: Zaten \" + new_mode + \" modundasin.\")\n            return\n\n        # Modu degistir\n        old_mode = current_mode\n        current_mode = new_mode\n        serial.write_line(\"MOD DEGISIMI: \" + old_mode + \" -> \" + current_mode)\n\n        # Yer istasyonuna mod degisimini bildir\n        send_ack(\"MODE\", current_mode)\n\n    # ============================================\n    # PARAMETRE YONETIMI\n    # ============================================\n\n    # Yer istasyonundan gelen parametre guncelleme komutlarini isler.\n    # Basarili guncellemede ACK OK, bilinmeyen parametrede ACK ERROR gonderir.\n    def handle_param_command(param_name, param_value):\n        global sample_rate, temp_threshold, light_threshold\n\n        # RATE parametresi: ornekleme hizini guncelle\n        if param_name == \"RATE\":\n            sample_rate = int(param_value)\n            serial.write_line(\"PARAM | RATE guncellendi: \" + str(sample_rate) + \"ms\")\n            send_ack(\"PARAM:RATE\", \"OK\")\n\n        # TEMP_THRESHOLD parametresi: sicaklik esigini guncelle\n        elif param_name == \"TEMP_THRESHOLD\":\n            temp_threshold = int(param_value)\n            serial.write_line(\"PARAM | TEMP_THRESHOLD guncellendi: \" + str(temp_threshold) + \" derece\")\n            send_ack(\"PARAM:TEMP_THRESHOLD\", \"OK\")\n\n        # LIGHT_THRESHOLD parametresi: isik esigini guncelle\n        elif param_name == \"LIGHT_THRESHOLD\":\n            light_threshold = int(param_value)\n            serial.write_line(\"PARAM | LIGHT_THRESHOLD guncellendi: \" + str(light_threshold))\n            send_ack(\"PARAM:LIGHT_THRESHOLD\", \"OK\")\n\n        # Bilinmeyen parametre - hata bildirimi gonder\n        else:\n            serial.write_line(\"PARAM | Bilinmeyen parametre: \" + param_name)\n            send_ack(\"PARAM:\" + param_name, \"ERROR\")\n\n    # ============================================\n    # MESAJ ALMA (CALLBACK)\n    # ============================================\n\n    # Radyodan gelen string mesajlari isle.\n    # Desteklenen komutlar: CMD:<id>:MODE:<mod> ve CMD:<id>:PARAM:<ad>:<deger>\n    def on_received_string(receivedString):\n        # Sadece CMD ile baslayan mesajlari isle\n        if not receivedString.startswith(\"CMD\"):\n            return\n\n        # Mesaji \":\" karakterine gore parcalara ayir\n        parts = receivedString.split(\":\")\n\n        # En az 3 parca olmali: CMD, id, komut_tipi\n        if len(parts) < 3:\n            return\n\n        # Bu komut bize mi? (satellite_id kontrolu)\n        if parts[1] != str(satellite_id):\n            return\n\n        cmd_type = parts[2]   # MODE veya PARAM\n\n        # --- MODE KOMUTU ---\n        # Format: CMD:<id>:MODE:<yeni_mod>\n        if cmd_type == \"MODE\" and len(parts) >= 4:\n            new_mode = parts[3]\n            change_mode(new_mode)\n\n        # --- PARAM KOMUTU ---\n        # Format: CMD:<id>:PARAM:<parametre_adi>:<deger>\n        # En az 5 parca olmali\n        elif cmd_type == \"PARAM\" and len(parts) >= 5:\n            param_name = parts[3]    # Ornek: RATE, TEMP_THRESHOLD\n            param_value = parts[4]   # Ornek: 5000, 30\n            handle_param_command(param_name, param_value)\n\n        else:\n            serial.write_line(\"MESAJ | Tanimsiz komut: \" + receivedString)\n\n    radio.on_received_string(on_received_string)\n\n    # ============================================\n    # BUTON ISLEMLERI\n    # ============================================\n\n    # Buton A: Guncel parametrelerin tamamini serial monitore yazdirir.\n    def on_button_pressed_a():\n        serial.write_line(\"========== GUNCEL PARAMETRELER ==========\")\n        serial.write_line(\"Mod           : \" + current_mode)\n        serial.write_line(\"RATE          : \" + str(sample_rate) + \" ms\")\n        serial.write_line(\"TEMP_THRESHOLD: \" + str(temp_threshold) + \" derece\")\n        serial.write_line(\"LIGHT_THRESHOLD: \" + str(light_threshold))\n        serial.write_line(\"Buffer Kayit  : \" + str(buffer_count) + \"/\" + str(MAX_BUFFER))\n        serial.write_line(\"=========================================\")\n\n    input.on_button_pressed(Button.A, on_button_pressed_a)\n\n    # ============================================\n    # ANA DONGU\n    # ============================================\n\n    # Surekli calisan dongu: aktif moda gore dogru fonksiyonu cagirir\n    # ve her mod icin belirlenmis bekleme suresini uygular.\n    def on_forever():\n        # SLEEP modu: enerjiden tasarruf et, 60 saniye bekle\n        if current_mode == \"SLEEP\":\n            mode_sleep()\n            basic.pause(60000)\n\n        # STANDBY modu: gozlem yap, 10 saniye bekle\n        elif current_mode == \"STANDBY\":\n            mode_standby()\n            basic.pause(10000)\n\n        # COLLECT modu: veri topla, 2 saniye bekle (hizli ornekleme)\n        elif current_mode == \"COLLECT\":\n            mode_collect()\n            basic.pause(2000)\n\n        # TRANSMIT modu: veri gonder, 5 saniye bekle\n        elif current_mode == \"TRANSMIT\":\n            mode_transmit()\n            basic.pause(5000)\n\n    basic.forever(on_forever)\n    basic.show_string(\"HW3\")\nbasic.forever(on_forever)\n"}]},{"timestamp":1773265491389,"editorVersion":"8.0.18","changes":[{"type":"edited","filename":"main.blocks","patch":[{"start1":0,"length1":84,"diffs":[[1,"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"pxt-on-start\" x=\"20\" y=\"20\"></block><block type=\"device_forever\" x=\"225\" y=\"20\"></block></xml>"]]}]},{"type":"edited","filename":"main.ts","patch":[{"start1":303,"length1":0,"diffs":[[1,"basic.forever(function on_forever() {\n    function send_ack(cmd_name: string, status: string) {\n        let ack = \"A:\" + (\"\" + satelli